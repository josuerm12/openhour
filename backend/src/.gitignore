# Backend source folder
#
# This file only applies inside backend/src. Most Java/Spring Boot build output
# is ignored by the project-level .gitignore because target/ and build/ usually
# live under backend/, not backend/src/.

# Compiled Java files should not be committed from source folders.
*.class

# Local scratch files created while testing backend code.
*.tmp
*.log

# Keep local-only Spring config out of source if one is ever created here.
application-local.properties
application-dev.properties
application-prod.properties
